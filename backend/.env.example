# Rename this file to .env before running the backend

# SQLite is used by default so you can run this project with zero setup.
# For production (per the project spec) swap this for a PostgreSQL URL, e.g.:
# DATABASE_URL=postgresql://user:password@localhost:5432/sports_injury_db
DATABASE_URL=sqlite:///./sports_injury.db

SECRET_KEY=change-this-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60
