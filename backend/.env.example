# Copy this file to .env and adjust as needed
# Default uses SQLite so you can run instantly with zero setup.
# To use PostgreSQL instead, uncomment and edit the line below.

DATABASE_URL=sqlite:///./sports_injury.db
# DATABASE_URL=postgresql://postgres:password@localhost:5432/sports_injury

SECRET_KEY=change-this-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256
